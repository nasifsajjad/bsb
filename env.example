# Supabase – copy these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key – REQUIRED for admin features (invite/delete users)
# Found in Supabase Settings → API → service_role key
# NEVER expose this in client-side code or commit it to version control
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
