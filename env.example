# ─────────────────────────────────────────────────────────────
# UYF Management System — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Supabase – copy from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key – REQUIRED for admin features (invite/delete users)
# Supabase Dashboard → Settings → API → service_role key
# This key bypasses RLS — keep it SECRET, server-side only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────────────
# SUPABASE ONE-TIME SETUP CHECKLIST
# ─────────────────────────────────────────────────────────────
#
# 1. Authentication → URL Configuration:
#    - Site URL:      https://your-app.vercel.app  (or http://localhost:3000 for dev)
#    - Redirect URLs: https://your-app.vercel.app/auth/callback
#                     http://localhost:3000/auth/callback
#
# 2. Run SQL migrations in order (Supabase → SQL Editor):
#    - supabase/migrations/001_initial_schema.sql
#    - supabase/migrations/002_improvements.sql
#
# 3. Promote the FIRST super admin (run once after they sign up):
#    UPDATE profiles SET role = 'super_admin'
#    WHERE id = (SELECT id FROM profiles ORDER BY created_at LIMIT 1);
#
# 4. Verify Storage buckets were created: logos (public) + avatars (public)
#
# 5. All further user management is done at /dashboard/users in the web app.
#    No ongoing Supabase dashboard access is needed after setup.
# ─────────────────────────────────────────────────────────────
